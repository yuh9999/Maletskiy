#include <bits/stdc++.h>
using namespace std;

class Counter{
  
private:
    int id;  // уникальный идентификатор счетчика
    static int totalCounters; // общее количество существующих счетчиков требования
  
public:
    Counter(){
        totalCounters++;
        id = totalCounters;
        cout<< "cчетчик #"<<  id << " создан "<<endl;
    }
    
    ~Counter(){
         totalCounters--;
          cout << "cчётчик #" << id << " уничтожен " << endl;
    }
    static int  getTotalCounters(){
        return totalCounters;
    }
    
};

int Counter::totalCounters = 0; // создани статического поля

int main(){
    int n;
    cout << "cколько счётчиков создать? "<<endl;
    cin >> n;
    
    Counter* counters = new Counter[n]; // cозданидинамического массива
    cout <<endl << "общее количество существующих счётчиков: " << Counter::getTotalCounters() << endl;
    delete[] counters; // удаляем динмический массив
    cout << "общее количество существующих счётчиков: " << Counter::getTotalCounters() << endl;
}

