#include <bits/stdc++.h>
using namespace std;

class Message{
private:
    string text;
    
public:
    Message(const string& value){
        text = value;
        cout<<"создано сообщение: " << text<<endl;
    }
    
    ~Message(){
        cout<<"сообщение удалено: " << text<<endl;
    }
    void print() const {
        cout<<text<<endl;
    }
    
    
};
    

int main() {
	setlocale(LC_ALL,"ru");
    Message statMessage("привет"); // создание статического объекта через стек
    statMessage.print();
    Message* dynMessage = new Message("пока"); // создание диномического объекта в куче
    dynMessage->print();
    delete dynMessage;
}




