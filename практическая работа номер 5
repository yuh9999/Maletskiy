#include <bits/stdc++.h>
using namespace std;



class Point2D {
 
public:
    
    Point2D(int valueX, int valueY) {
        x = valueX; 
        y = valueY;  
        pointCount++;  
        cout << "точка: "<< x << "  " << y << endl;
    }
    Point2D(const Point2D& other) {
        x = other.x;  
        y = other.y;  
        pointCount++;  
        cout << "копия точки:"<<x<<"  "<< y<<endl;
    }
    ~Point2D() {
        pointCount--;  
        cout << "точка удалена:" << x << "  "<< y<< endl;
    }
    static int getPointCount() {
        return pointCount;
    }
    void print() const {
        cout << "точка:" << x << " "<< y <<endl;
    }
private:
    int x, y;  
    static int pointCount; 

};
int Point2D::pointCount = 0;

void demonstrateCopy(Point2D p) {
    cout << "внутри функции: ";
    p.print();
}
int main() {
    cout << "начальное количество точек: " << Point2D::getPointCount() << endl << endl;
    Point2D p1(3, 4);
    cout << "количество точек после создания p1: " << Point2D::getPointCount() << endl;
    Point2D p2(p1);
    cout << "количество точек после создания p2: " << Point2D::getPointCount() << endl;
    Point2D p3 = p1;
    cout << "количество точек после создания p3: " << Point2D::getPointCount() << endl;
    cout << "количество точек перед вызовом функции: " << Point2D::getPointCount() << endl;
    demonstrateCopy(p1);  
    cout << "количество точек после вызова функции: " << Point2D::getPointCount() << endl ;
    cout << "финальное количество точек: " << Point2D::getPointCount() << endl;
    return 0;
}



