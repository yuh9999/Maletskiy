#include <bits/stdc++.h>
using namespace std;
class Book {
public:
    Book(string title, string author, int year) {
        this->title = title;
        this->author = author;
        this->year = year;
        if (year > 2026 || year < 1450) {
            cout << "предупреждение: некорректный год издания!" << endl;
        } else {
            cout << "книга: " << title << endl;
            cout << "добавлена в каталог: " << year << endl;
        }
    }
    void getBookInfo() {
        cout << "книга: " << title << endl;
        cout << "автор: " << author << endl;
        cout << "год: " << year << endl;
    }
private:
    string title;
    string author;
    int year;
};
int main() {
    Book a("война и мир", "Лев Толстой", 1869);
    a.getBookInfo();
    Book b("неизвестная книга", "неизвестный автор", 1292);
    b.getBookInfo();
    return 0;
}

