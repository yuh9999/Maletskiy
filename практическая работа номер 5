#include <bits/stdc++.h>
using namespace std;

class DynamicArray {

public:
    DynamicArray(int s) {
        size = s;                            
        data = new int[size];          
        for (int i = 0; i < size; i++) {
            data[i] = i + 1;
        }
    }
    ~DynamicArray() {
        delete[] data;
    }
    DynamicArray(const DynamicArray& other) {
        size = other.size;               
        data = new int[size];       
        for (int i = 0; i < size; i++) {
            data[i] = other.data[i];
        }
    }
    void print() const {
        for (int i = 0; i < size; i++) {
            cout << data[i] << " ";
        }
        cout << endl;
    }
    void setValue(int index, int value) {
        if (index >= 0 && index < size) {
            data[index] = value;
        } else {
            cout << "ошибка в  индексе " << index << " выходит за границы массива" << size << endl;
        }
    }
private:
    int* data; 
    int size;   

};
int main() {
    DynamicArray arr1(5);
    cout << "arr1: ";
    arr1.print();
    cout << endl;

   
    DynamicArray arr2(arr1);  
    cout << "arr2: ";
    arr2.print();
    cout << endl;


    arr1.setValue(2, 99);
    cout << "arr1 после изменения: ";
    arr1.print();
    cout << "arr2 после изменения arr1: ";
    arr2.print();
    cout << endl;
    
    arr1.setValue(10, 50);  
    cout << endl;

    return 0;
}



